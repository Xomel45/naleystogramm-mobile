<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="3dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Avatar circle with initial -->
        <TextView
            android:id="@+id/avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Status dot -->
        <View
            android:id="@+id/status_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_status_dot"
            app:layout_constraintEnd_toEndOf="@id/avatar"
            app:layout_constraintBottom_toBottomOf="@id/avatar" />

        <!-- Name -->
        <TextView
            android:id="@+id/contact_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/avatar"
            app:layout_constraintEnd_toStartOf="@id/unread_badge"
            android:layout_marginStart="12dp" />

        <!-- Last message -->
        <TextView
            android:id="@+id/last_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@id/contact_name"
            app:layout_constraintStart_toEndOf="@id/avatar"
            app:layout_constraintEnd_toStartOf="@id/latency"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp" />

        <!-- Latency label -->
        <TextView
            android:id="@+id/latency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@id/last_message"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Unread badge -->
        <TextView
            android:id="@+id/unread_badge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_unread_badge"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/contact_name"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
